#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
run_id="${KATL_INSTALLED_FIXTURE_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
state_root="${KATL_INSTALLED_FIXTURE_STATE_ROOT:-$repo_root/build/installed-runtime-fixture}"
state_dir="${KATL_INSTALLED_FIXTURE_STATE_DIR:-$state_root/$run_id}"
env_file="${KATL_INSTALLED_FIXTURE_ENV:-$state_dir/vmtest.env}"
run_script="$state_dir/run-installed-runtime-vmtest-agent.sh"
ready_run_script="$state_dir/run-installed-runtime-kubeadm-ready.sh"
manifest="$state_dir/fixture.json"

disk="${KATL_INSTALLED_DISK:-}"
esp_artifacts="${KATL_INSTALLED_ESP_ARTIFACTS:-}"
fixture_manifest="${KATL_INSTALLED_FIXTURE_MANIFEST:-}"
node_metadata="${KATL_INSTALLED_NODE_METADATA:-}"
disk_format="${KATL_INSTALLED_DISK_FORMAT:-raw}"
vmtest_keep="${KATL_VMTEST_KEEP:-failed}"
vmtest_state_root="${KATL_VMTEST_STATE_ROOT:-$state_dir/vm-runs}"
env_file_set=0
check_only=0

usage() {
    cat <<'USAGE'
Usage: scripts/resolve-installed-runtime-fixture [options]

Resolve and preflight one installed Katl runtime fixture for the opt-in
installed-runtime vmtest-agent smoke. The fixture manifest must bind the disk
and rendered ESP artifact tree by checksum so the smoke runs against artifacts
from a real install-to-runtime flow instead of loose paths.

Options:
  --disk PATH          Installed runtime disk, or KATL_INSTALLED_DISK
  --esp-artifacts DIR  Rendered ESP artifact tree, or KATL_INSTALLED_ESP_ARTIFACTS
  --fixture P          InstalledRuntimeVMTestFixture manifest, or KATL_INSTALLED_FIXTURE_MANIFEST
  --node-metadata P    Optional /etc/katl/node.json, or KATL_INSTALLED_NODE_METADATA
  --format F           Disk image format: raw or qcow2 (default: raw)
  --state-dir DIR      Output directory for generated env, manifest, and wrapper
  --env-file PATH      Sourceable env output path (default: <state-dir>/vmtest.env)
  --check-only         Validate manifest bindings and ESP preflight without writing wrappers
  -h, --help           Show this help

After this command succeeds:
  source <state-dir>/vmtest.env
  <state-dir>/run-installed-runtime-vmtest-agent.sh
  <state-dir>/run-installed-runtime-kubeadm-ready.sh
USAGE
}

fail() {
    echo "error: $*" >&2
    exit 1
}

need_value() {
    local option="$1"
    local value="${2:-}"
    if [[ -z "$value" || "$value" == --* ]]; then
        fail "$option requires a value"
    fi
}

need() {
    command -v "$1" >/dev/null 2>&1 || fail "$1 is required"
}

rel() {
    local path="$1"
    printf "%s" "${path#"$repo_root"/}"
}

json() {
    local value="$1"
    value="${value//\\/\\\\}"
    value="${value//\"/\\\"}"
    value="${value//$'\n'/\\n}"
    printf "%s" "$value"
}

real() {
    realpath -m "$1"
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --disk)
            need_value "$1" "${2:-}"
            disk="$2"
            shift 2
            ;;
        --esp-artifacts)
            need_value "$1" "${2:-}"
            esp_artifacts="$2"
            shift 2
            ;;
        --fixture|--fixture-manifest)
            need_value "$1" "${2:-}"
            fixture_manifest="$2"
            shift 2
            ;;
        --node-metadata)
            need_value "$1" "${2:-}"
            node_metadata="$2"
            shift 2
            ;;
        --format)
            need_value "$1" "${2:-}"
            disk_format="$2"
            shift 2
            ;;
        --state-dir)
            need_value "$1" "${2:-}"
            state_dir="$2"
            if [[ "$env_file_set" -eq 0 ]]; then
                env_file="$state_dir/vmtest.env"
            fi
            run_script="$state_dir/run-installed-runtime-vmtest-agent.sh"
            ready_run_script="$state_dir/run-installed-runtime-kubeadm-ready.sh"
            manifest="$state_dir/fixture.json"
            vmtest_state_root="$state_dir/vm-runs"
            shift 2
            ;;
        --env-file)
            need_value "$1" "${2:-}"
            env_file="$2"
            env_file_set=1
            shift 2
            ;;
        --check-only)
            check_only=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage >&2
            fail "unknown argument: $1"
            ;;
    esac
done

case "$disk_format" in
    qcow2|raw) ;;
    *) fail "--format must be raw or qcow2" ;;
esac

[[ -n "$disk" ]] || fail "--disk is required"
[[ -f "$disk" ]] || fail "installed disk not found: $(rel "$disk")"
[[ -n "$esp_artifacts" ]] || fail "--esp-artifacts is required"
[[ -d "$esp_artifacts" ]] || fail "ESP artifacts directory not found: $(rel "$esp_artifacts")"
[[ -n "$fixture_manifest" ]] || fail "--fixture is required"
[[ -f "$fixture_manifest" ]] || fail "fixture manifest not found: $(rel "$fixture_manifest")"
if [[ -n "$node_metadata" ]]; then
    [[ -f "$node_metadata" ]] || fail "node metadata not found: $(rel "$node_metadata")"
fi

need jq
need sha256sum

disk="$(real "$disk")"
esp_artifacts="$(real "$esp_artifacts")"
fixture_manifest="$(real "$fixture_manifest")"
if [[ -n "$node_metadata" ]]; then
    node_metadata="$(real "$node_metadata")"
fi
state_dir="$(real "$state_dir")"
env_file="$(real "$env_file")"
run_script="$(real "$run_script")"
ready_run_script="$(real "$ready_run_script")"
manifest="$(real "$manifest")"
vmtest_state_root="$(real "$vmtest_state_root")"

file_sha() {
    sha256sum "$1" | awk '{print $1}'
}

tree_sha() {
    local root="$1"
    (
        cd "$root"
        while IFS= read -r -d '' path; do
            local rel_path="${path#./}"
            local mode
            mode="$(stat -c '%a' "$path")"
            if [[ -L "$path" ]]; then
                fail "ESP artifacts contain unsupported non-regular entry: $rel_path"
            elif [[ -d "$path" ]]; then
                printf 'dir %s %s\n' "$mode" "$rel_path"
            elif [[ -f "$path" ]]; then
                printf 'file %s %s %s\n' "$mode" "$(file_sha "$path")" "$rel_path"
            else
                fail "ESP artifacts contain unsupported non-regular entry: $rel_path"
            fi
        done < <(find . -mindepth 1 -print0 | sort -z)
    ) | sha256sum | awk '{print $1}'
}

manifest_path() {
    local query="$1"
    local value base
    value="$(jq -er "$query" "$fixture_manifest")"
    base="$(dirname "$fixture_manifest")"
    if [[ "$value" == /* ]]; then
        real "$value"
    else
        real "$base/$value"
    fi
}

jq -e '
    .apiVersion == "katl.dev/v1alpha1" and
    .kind == "InstalledRuntimeVMTestFixture" and
    (.disk.path | type == "string") and
    (.espArtifacts.path | type == "string")
    ' "$fixture_manifest" >/dev/null ||
    fail "$fixture_manifest must be an InstalledRuntimeVMTestFixture with disk and espArtifacts"

manifest_disk="$(manifest_path '.disk.path')"
manifest_esp="$(manifest_path '.espArtifacts.path')"
[[ "$manifest_disk" == "$disk" ]] || fail "fixture disk path $manifest_disk does not match $disk"
[[ "$manifest_esp" == "$esp_artifacts" ]] || fail "fixture ESP path $manifest_esp does not match $esp_artifacts"
[[ "$(jq -er '.disk.format' "$fixture_manifest")" == "$disk_format" ]] || fail "fixture disk format does not match $disk_format"
[[ "$(file_sha "$disk")" == "$(jq -er '.disk.sha256' "$fixture_manifest")" ]] || fail "fixture disk sha256 does not match $disk"
[[ "$(tree_sha "$esp_artifacts")" == "$(jq -er '.espArtifacts.treeSHA256' "$fixture_manifest")" ]] || fail "fixture ESP treeSHA256 does not match $esp_artifacts"

if jq -e 'has("nodeMetadata")' "$fixture_manifest" >/dev/null; then
    manifest_metadata="$(manifest_path '.nodeMetadata.path')"
    if [[ -n "$node_metadata" ]]; then
        [[ "$manifest_metadata" == "$node_metadata" ]] || fail "fixture node metadata path $manifest_metadata does not match $node_metadata"
    else
        node_metadata="$manifest_metadata"
    fi
    [[ -f "$node_metadata" ]] || fail "fixture node metadata not found: $(rel "$node_metadata")"
    [[ "$(file_sha "$node_metadata")" == "$(jq -er '.nodeMetadata.sha256' "$fixture_manifest")" ]] || fail "fixture node metadata sha256 does not match $node_metadata"
fi

mkdir -p "$state_dir"
"$repo_root/scripts/check-installed-disk-smoke" \
    --disk "$disk" \
    --format "$disk_format" \
    --esp-artifacts "$esp_artifacts" \
    --state-dir "$state_dir/preflight" \
    --preflight-only >/dev/null

if [[ "$check_only" -eq 1 ]]; then
    echo "ok: installed runtime fixture bindings valid"
    exit 0
fi

mkdir -p "$(dirname "$env_file")" "$(dirname "$run_script")" "$(dirname "$ready_run_script")" "$(dirname "$manifest")"
{
    printf '# Generated by scripts/resolve-installed-runtime-fixture\n'
    printf '# Source this file before running installed-runtime vmtest smokes.\n'
    printf 'export KATL_VMTEST_RUN=%q\n' "1"
    printf 'export KATL_VMTEST_KEEP=%q\n' "$vmtest_keep"
    printf 'export KATL_VMTEST_STATE_ROOT=%q\n' "$vmtest_state_root"
    printf 'export KATL_INSTALLED_DISK=%q\n' "$disk"
    printf 'export KATL_INSTALLED_DISK_FORMAT=%q\n' "$disk_format"
    printf 'export KATL_INSTALLED_ESP_ARTIFACTS=%q\n' "$esp_artifacts"
    printf 'export KATL_INSTALLED_FIXTURE_MANIFEST=%q\n' "$fixture_manifest"
    if [[ -n "$node_metadata" ]]; then
        printf 'export KATL_INSTALLED_NODE_METADATA=%q\n' "$node_metadata"
    fi
} >"$env_file"

{
    printf '#!/usr/bin/env bash\n'
    printf 'set -euo pipefail\n'
    printf 'cd %q\n' "$repo_root"
    printf 'source %q\n' "$env_file"
    printf 'recheck_dir=%q\n' "$state_dir/recheck"
    # shellcheck disable=SC2016
    printf 'recheck_args=(--disk "$KATL_INSTALLED_DISK" --esp-artifacts "$KATL_INSTALLED_ESP_ARTIFACTS" --fixture "$KATL_INSTALLED_FIXTURE_MANIFEST" --format "${KATL_INSTALLED_DISK_FORMAT:-raw}" --state-dir "$recheck_dir" --check-only)\n'
    # shellcheck disable=SC2016
    printf 'if [[ -n "${KATL_INSTALLED_NODE_METADATA:-}" ]]; then\n'
    # shellcheck disable=SC2016
    printf '    recheck_args+=(--node-metadata "$KATL_INSTALLED_NODE_METADATA")\n'
    printf 'fi\n'
    # shellcheck disable=SC2016
    printf '%q "${recheck_args[@]}"\n' "$repo_root/scripts/resolve-installed-runtime-fixture"
    # shellcheck disable=SC2016
    printf 'GOCACHE="${GOCACHE:-/tmp/katl-go-cache}" go test ./internal/vmtest -run '\''^TestInstalledRuntimeVMTestAgentSmoke$'\'' -count=1 -timeout 10m -katl.vmtest.run\n'
} >"$run_script"
chmod +x "$run_script"

{
    printf '#!/usr/bin/env bash\n'
    printf 'set -euo pipefail\n'
    printf 'cd %q\n' "$repo_root"
    printf 'source %q\n' "$env_file"
    printf 'recheck_dir=%q\n' "$state_dir/recheck-kubeadm-ready"
    # shellcheck disable=SC2016
    printf 'recheck_args=(--disk "$KATL_INSTALLED_DISK" --esp-artifacts "$KATL_INSTALLED_ESP_ARTIFACTS" --fixture "$KATL_INSTALLED_FIXTURE_MANIFEST" --format "${KATL_INSTALLED_DISK_FORMAT:-raw}" --state-dir "$recheck_dir" --check-only)\n'
    # shellcheck disable=SC2016
    printf 'if [[ -n "${KATL_INSTALLED_NODE_METADATA:-}" ]]; then\n'
    # shellcheck disable=SC2016
    printf '    recheck_args+=(--node-metadata "$KATL_INSTALLED_NODE_METADATA")\n'
    printf 'fi\n'
    # shellcheck disable=SC2016
    printf '%q "${recheck_args[@]}"\n' "$repo_root/scripts/resolve-installed-runtime-fixture"
    # shellcheck disable=SC2016
    printf 'GOCACHE="${GOCACHE:-/tmp/katl-go-cache}" go test ./internal/vmtest -run '\''^TestInstalledRuntimeKubeadmReadySmoke$'\'' -count=1 -timeout 10m -katl.vmtest.run\n'
} >"$ready_run_script"
chmod +x "$ready_run_script"

cat >"$manifest" <<EOF
{
  "apiVersion": "katl.dev/v1alpha1",
  "kind": "InstalledRuntimeVMTestFixtureResolution",
  "disk": "$(json "$disk")",
  "diskFormat": "$(json "$disk_format")",
  "espArtifacts": "$(json "$esp_artifacts")",
  "fixtureManifest": "$(json "$fixture_manifest")",
  "nodeMetadata": "$(json "$node_metadata")",
  "preflightRunDir": "$(json "$state_dir/preflight")",
  "envFile": "$(json "$env_file")",
  "runScript": "$(json "$run_script")",
  "kubeadmReadyRunScript": "$(json "$ready_run_script")"
}
EOF

echo "fixture env: $(rel "$env_file")"
echo "fixture manifest: $(rel "$manifest")"
echo "run script: $(rel "$run_script")"
echo "kubeadm-ready run script: $(rel "$ready_run_script")"
echo "next: source $(rel "$env_file")"
echo "next: $(rel "$run_script")"
echo "next: $(rel "$ready_run_script")"
