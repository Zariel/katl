#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
run_id="${KATL_INSTALLED_FIXTURE_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
state_root="${KATL_INSTALLED_FIXTURE_STATE_ROOT:-$repo_root/build/installed-runtime-fixture}"
state_dir="${KATL_INSTALLED_FIXTURE_STATE_DIR:-$state_root/$run_id}"
fixture_manifest="$state_dir/installed-runtime-fixture.json"

disk="${KATL_INSTALLED_DISK:-}"
esp_artifacts="${KATL_INSTALLED_ESP_ARTIFACTS:-}"
node_metadata="${KATL_INSTALLED_NODE_METADATA:-}"
disk_format="${KATL_INSTALLED_DISK_FORMAT:-raw}"
node_name="${KATL_INSTALLED_FIXTURE_NODE_NAME:-}"
system_role="${KATL_INSTALLED_FIXTURE_SYSTEM_ROLE:-}"
artifact_mode="${KATL_INSTALLED_FIXTURE_ARTIFACT_MODE:-copy}"
run_smoke=0

usage() {
    cat <<'USAGE'
Usage: scripts/create-installed-runtime-fixture --disk PATH --esp-artifacts DIR [options]

Package completed install-to-runtime outputs into the checksum-bound installed
runtime fixture contract consumed by the installed-runtime vmtest smokes.

Options:
  --disk PATH             Installed runtime disk, or KATL_INSTALLED_DISK
  --esp-artifacts DIR     Rendered ESP artifact tree, or KATL_INSTALLED_ESP_ARTIFACTS
  --node-metadata PATH    Optional /etc/katl/node.json, or KATL_INSTALLED_NODE_METADATA
  --format F              Disk image format: raw or qcow2 (default: raw)
  --node-name NAME        Fixture node name; derived from node metadata when present
  --system-role ROLE      Fixture role; derived from node metadata when present
  --artifact-mode MODE    copy or reference artifacts in the fixture (default: copy)
  --state-dir DIR         Output directory for fixture, env, manifest, and wrapper
  --run-smoke             Run the generated installed-runtime vmtest-agent wrapper
  -h, --help              Show this help

After this command succeeds:
  source <state-dir>/vmtest.env
  <state-dir>/run-installed-runtime-vmtest-agent.sh
  <state-dir>/run-installed-runtime-kubeadm-ready.sh
USAGE
}

fail() {
    echo "error: $*" >&2
    exit 1
}

need_value() {
    local option="$1"
    local value="${2:-}"
    if [[ -z "$value" || "$value" == --* ]]; then
        fail "$option requires a value"
    fi
}

need() {
    command -v "$1" >/dev/null 2>&1 || fail "$1 is required"
}

rel() {
    local path="$1"
    printf "%s" "${path#"$repo_root"/}"
}

real() {
    realpath -m "$1"
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --disk)
            need_value "$1" "${2:-}"
            disk="$2"
            shift 2
            ;;
        --esp-artifacts)
            need_value "$1" "${2:-}"
            esp_artifacts="$2"
            shift 2
            ;;
        --node-metadata)
            need_value "$1" "${2:-}"
            node_metadata="$2"
            shift 2
            ;;
        --format)
            need_value "$1" "${2:-}"
            disk_format="$2"
            shift 2
            ;;
        --node-name)
            need_value "$1" "${2:-}"
            node_name="$2"
            shift 2
            ;;
        --system-role)
            need_value "$1" "${2:-}"
            system_role="$2"
            shift 2
            ;;
        --artifact-mode)
            need_value "$1" "${2:-}"
            artifact_mode="$2"
            shift 2
            ;;
        --state-dir)
            need_value "$1" "${2:-}"
            state_dir="$2"
            fixture_manifest="$state_dir/installed-runtime-fixture.json"
            shift 2
            ;;
        --run-smoke)
            run_smoke=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            usage >&2
            fail "unknown argument: $1"
            ;;
    esac
done

case "$disk_format" in
    qcow2|raw) ;;
    *) fail "--format must be raw or qcow2" ;;
esac
case "$artifact_mode" in
    copy|reference) ;;
    *) fail "--artifact-mode must be copy or reference" ;;
esac

[[ -n "$disk" ]] || fail "--disk is required"
[[ -f "$disk" ]] || fail "installed disk not found: $(rel "$disk")"
[[ -n "$esp_artifacts" ]] || fail "--esp-artifacts is required"
[[ -d "$esp_artifacts" ]] || fail "ESP artifacts directory not found: $(rel "$esp_artifacts")"
if [[ -n "$node_metadata" ]]; then
    [[ -f "$node_metadata" ]] || fail "node metadata not found: $(rel "$node_metadata")"
fi

need jq
need sha256sum

disk="$(real "$disk")"
esp_artifacts="$(real "$esp_artifacts")"
if [[ -n "$node_metadata" ]]; then
    node_metadata="$(real "$node_metadata")"
fi
state_dir="$(real "$state_dir")"
fixture_manifest="$(real "$fixture_manifest")"

metadata_node=""
metadata_role=""
if [[ -n "$node_metadata" ]]; then
    jq -e '
        .apiVersion == "katl.dev/v1alpha1" and
        .kind == "NodeMetadata" and
        (.identity.hostname | type == "string" and length > 0) and
        (.systemRole | type == "string" and length > 0)
        ' "$node_metadata" >/dev/null ||
        fail "$node_metadata must be Katl NodeMetadata with identity.hostname and systemRole"
    metadata_node="$(jq -er '.identity.hostname // empty' "$node_metadata")" ||
        fail "$node_metadata must contain .identity.hostname"
    metadata_role="$(jq -er '.systemRole // empty' "$node_metadata")" ||
        fail "$node_metadata must contain .systemRole"
    if [[ -n "$node_name" && "$node_name" != "$metadata_node" ]]; then
        fail "--node-name $node_name does not match node metadata hostname $metadata_node"
    fi
    if [[ -n "$system_role" && "$system_role" != "$metadata_role" ]]; then
        fail "--system-role $system_role does not match node metadata role $metadata_role"
    fi
    node_name="$metadata_node"
    system_role="$metadata_role"
fi
node_name="${node_name:-node-1}"
system_role="${system_role:-control-plane}"
[[ "$node_name" =~ ^[A-Za-z0-9._-]+$ ]] || fail "node name must contain only letters, digits, dot, underscore, or dash"
case "$system_role" in
    control-plane|worker) ;;
    *) fail "system role must be control-plane or worker" ;;
esac

file_sha() {
    sha256sum "$1" | awk '{print $1}'
}

tree_sha() {
    local root="$1"
    (
        cd "$root"
        while IFS= read -r -d '' path; do
            local rel_path="${path#./}"
            local mode
            mode="$(stat -c '%a' "$path")"
            if [[ -L "$path" ]]; then
                fail "ESP artifacts contain unsupported non-regular entry: $rel_path"
            elif [[ -d "$path" ]]; then
                printf 'dir %s %s\n' "$mode" "$rel_path"
            elif [[ -f "$path" ]]; then
                printf 'file %s %s %s\n' "$mode" "$(file_sha "$path")" "$rel_path"
            else
                fail "ESP artifacts contain unsupported non-regular entry: $rel_path"
            fi
        done < <(find . -mindepth 1 -print0 | sort -z)
    ) | sha256sum | awk '{print $1}'
}

manifest_path() {
    local path="$1"
    if [[ "$artifact_mode" == reference ]]; then
        printf "%s" "$path"
    else
        printf "%s" "${path#"$state_dir"/}"
    fi
}

mkdir -p "$state_dir"

if [[ "$artifact_mode" == copy ]]; then
    staged_disk="$state_dir/installed-runtime.$disk_format"
    staged_esp="$state_dir/esp"
    staged_metadata=""
    cp --reflink=auto "$disk" "$staged_disk"
    rm -rf "$staged_esp"
    cp -a "$esp_artifacts" "$staged_esp"
    if [[ -n "$node_metadata" ]]; then
        staged_metadata="$state_dir/node.json"
        cp "$node_metadata" "$staged_metadata"
    fi
else
    staged_disk="$disk"
    staged_esp="$esp_artifacts"
    staged_metadata="$node_metadata"
fi

disk_sha="$(file_sha "$staged_disk")"
esp_sha="$(tree_sha "$staged_esp")"
metadata_path=""
metadata_sha=""
if [[ -n "$staged_metadata" ]]; then
    metadata_sha="$(file_sha "$staged_metadata")"
    metadata_path="$(manifest_path "$staged_metadata")"
fi

jq -n \
    --arg nodeName "$node_name" \
    --arg systemRole "$system_role" \
    --arg diskPath "$(manifest_path "$staged_disk")" \
    --arg diskFormat "$disk_format" \
    --arg diskSHA256 "$disk_sha" \
    --arg espPath "$(manifest_path "$staged_esp")" \
    --arg espTreeSHA256 "$esp_sha" \
    --arg nodeMetadataPath "$metadata_path" \
    --arg nodeMetadataSHA256 "$metadata_sha" \
    '{
      apiVersion: "katl.dev/v1alpha1",
      kind: "InstalledRuntimeVMTestFixture",
      nodeName: $nodeName,
      systemRole: $systemRole,
      disk: {
        path: $diskPath,
        format: $diskFormat,
        sha256: $diskSHA256
      },
      espArtifacts: {
        path: $espPath,
        treeSHA256: $espTreeSHA256
      }
    } + if $nodeMetadataPath == "" then {} else {
      nodeMetadata: {
        path: $nodeMetadataPath,
        sha256: $nodeMetadataSHA256
      }
    } end' >"$fixture_manifest"

resolve_args=(
    --disk "$staged_disk"
    --esp-artifacts "$staged_esp"
    --fixture "$fixture_manifest"
    --format "$disk_format"
    --state-dir "$state_dir"
)
if [[ -n "$staged_metadata" ]]; then
    resolve_args+=(--node-metadata "$staged_metadata")
fi

"$repo_root/scripts/resolve-installed-runtime-fixture" "${resolve_args[@]}"

if [[ "$run_smoke" -eq 1 ]]; then
    "$state_dir/run-installed-runtime-vmtest-agent.sh"
fi
