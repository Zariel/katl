#!/usr/bin/env bash
set -euo pipefail

virsh_bin="${KATL_VMTEST_VIRSH:-virsh}"
ps_bin="${KATL_VMTEST_PS:-ps}"
kill_bin="${KATL_VMTEST_KILL:-kill}"
sudo_bin="${KATL_VMTEST_SUDO:-sudo}"

usage() {
    printf 'usage: scripts/vmtest-clean <run-dir|result.json>\n' >&2
}

if [[ "$#" -ne 1 ]]; then
    usage
    exit 2
fi

target="$1"
if [[ -d "$target" ]]; then
    mapfile -t result_files < <(find "$target" -name result.json -print | sort)
elif [[ -f "$target" ]]; then
    result_files=("$target")
else
    printf 'vmtest-clean: target not found: %s\n' "$target" >&2
    exit 2
fi

if [[ "${#result_files[@]}" -eq 0 ]]; then
    printf 'vmtest-clean: no result.json files found under %s\n' "$target" >&2
    exit 2
fi

cleaned=0
kill_qemu_pid() {
    local pid="$1"
    local domain="$2"

    if "$kill_bin" "$pid" >/dev/null 2>&1; then
        return 0
    fi
    if command -v "$sudo_bin" >/dev/null 2>&1 && "$sudo_bin" -n "$kill_bin" "$pid" >/dev/null 2>&1; then
        return 0
    fi
    printf 'vmtest-clean: failed to kill orphan qemu pid %s for %s\n' "$pid" "$domain" >&2
    return 1
}

cleanup_orphan_qemu() {
    local domain="$1"
    local killed=0
    local failed=0
    local pid args

    while read -r pid args; do
        if [[ -z "$pid" || -z "${args:-}" ]]; then
            continue
        fi
        if [[ "$args" == *qemu-system* && ( "$args" == *"guest=${domain},"* || "$args" == *"guest=${domain} "* ) ]]; then
            printf 'vmtest-clean: killing orphan qemu pid %s for %s\n' "$pid" "$domain" >&2
            kill_qemu_pid "$pid" "$domain" || failed=1
            killed=$((killed + 1))
        fi
    done < <("$ps_bin" -eo pid=,args=)

    if [[ "$failed" -ne 0 ]]; then
        return 1
    fi
    return 0
}

wait_domain_inactive() {
    local domain="$1"
    local uri="$2"
    local state

    for _ in {1..50}; do
        state="$("$virsh_bin" -c "$uri" domstate "$domain" 2>/dev/null || true)"
        case "$state" in
            ""|*"shut off"*|*"no state"*|*"not found"*)
                return 0
                ;;
        esac
        sleep 0.1
    done
    return 1
}

domain_exists() {
    local domain="$1"
    local uri="$2"

    "$virsh_bin" -c "$uri" dominfo "$domain" >/dev/null 2>&1
}

for result in "${result_files[@]}"; do
    while IFS=$'\t' read -r domain uri; do
        if [[ -z "$domain" ]]; then
            printf 'vmtest-clean: refusing empty domain name in %s\n' "$result" >&2
            exit 2
        fi
        if [[ ! "$domain" =~ ^[A-Za-z0-9_.:-]+$ || "$domain" != katl-* ]]; then
            printf 'vmtest-clean: refusing unsafe domain name %q in %s\n' "$domain" "$result" >&2
            exit 2
        fi
        if [[ -z "$uri" ]]; then
            printf 'vmtest-clean: refusing empty libvirt URI for %s in %s\n' "$domain" "$result" >&2
            exit 2
        fi
        printf 'vmtest-clean: destroying %s on %s\n' "$domain" "$uri" >&2
        "$virsh_bin" -c "$uri" destroy "$domain" >/dev/null 2>&1 || {
            printf 'vmtest-clean: virsh destroy failed for %s; checking domain state\n' "$domain" >&2
        }
        if ! wait_domain_inactive "$domain" "$uri"; then
            printf 'vmtest-clean: %s is still active after destroy; checking for orphan qemu process\n' "$domain" >&2
            cleanup_orphan_qemu "$domain"
            if ! wait_domain_inactive "$domain" "$uri"; then
                printf 'vmtest-clean: failed to stop %s on %s\n' "$domain" "$uri" >&2
                exit 1
            fi
        fi
        printf 'vmtest-clean: undefining %s on %s\n' "$domain" "$uri" >&2
        "$virsh_bin" -c "$uri" undefine "$domain" --nvram >/dev/null 2>&1 || {
            printf 'vmtest-clean: virsh undefine failed for %s; checking for orphan qemu process\n' "$domain" >&2
            cleanup_orphan_qemu "$domain"
            if domain_exists "$domain" "$uri"; then
                printf 'vmtest-clean: failed to undefine %s on %s\n' "$domain" "$uri" >&2
                exit 1
            fi
        }
        cleaned=$((cleaned + 1))
    done < <(
        jq -r '
          (.debug.targets // [])
          | map(select(.preserved == true))
          | .[]
          | [.domainName, .libvirtURI]
          | @tsv
        ' "$result"
    )
done

if [[ "$cleaned" -eq 0 ]]; then
    printf 'vmtest-clean: no preserved vmtest domains recorded in %s\n' "$target" >&2
    exit 1
fi

printf 'vmtest-clean: cleaned %d preserved domain(s)\n' "$cleaned" >&2
