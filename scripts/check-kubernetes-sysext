#!/usr/bin/env bash
set -euo pipefail

artifact="${1:-build/mkosi/katl-kubernetes.raw}"
metadata="${artifact}.json"
checksum="${artifact}.sha256"
runtime_root="${KATL_RUNTIME_ROOT:-build/mkosi/katl-runtime-root}"
kube_manifest="${KATL_KUBERNETES_MANIFEST:-mkosi.profiles/kubernetes-sysext/kubernetes.env}"

if [[ ! -f "$kube_manifest" ]]; then
    echo "error: Kubernetes manifest not found: $kube_manifest" >&2
    exit 1
fi

# shellcheck source=mkosi.profiles/kubernetes-sysext/kubernetes.env
source "$kube_manifest"

fail() {
    echo "error: $*" >&2
    exit 1
}

need() {
    command -v "$1" >/dev/null 2>&1 || fail "$1 is required"
}

json_has() {
    grep -Fq "$1" "$metadata" || fail "metadata missing $1"
}

json_string() {
    local key="$1"
    sed -n "s/.*\"$key\": \"\\([^\"]*\\)\".*/\\1/p" "$metadata" | head -n 1
}

json_string_nonempty() {
    local key="$1"
    local value
    value="$(json_string "$key")"
    [[ -n "$value" ]] || fail "metadata missing non-empty $key"
    printf "%s" "$value"
}

json_expect_or_nonempty() {
    local key="$1"
    local want="$2"
    local value
    value="$(json_string_nonempty "$key")"
    if [[ -n "$want" && "$value" != "$want" ]]; then
        fail "metadata $key = $value, want $want"
    fi
}

payload_version_from_package() {
    local version="$1"
    version="${version#*:}"
    version="${version%%-*}"
    [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || fail "cannot derive Kubernetes payload version from package version $1"
    printf "v%s" "$version"
}

has_path() {
    local path="$1"
    local output
    output="$(dump.erofs --path "$path" "$part" 2>&1)" || fail "inspect $path failed"
    if grep -Fq "read inode failed" <<<"$output"; then
        fail "missing sysext path: $path"
    fi
}

misses_path() {
    local path="$1"
    local output
    output="$(dump.erofs --path "$path" "$part" 2>&1)" || fail "inspect $path failed"
    if ! grep -Fq "read inode failed" <<<"$output"; then
        fail "unexpected sysext path: $path"
    fi
}

need awk
need dd
need dump.erofs
need fdisk
need fsck.erofs
need grep
need sha256sum
need stat

[[ -f "$artifact" ]] || fail "artifact not found: $artifact"
[[ -f "$metadata" ]] || fail "metadata not found: $metadata"
[[ -f "$checksum" ]] || fail "checksum not found: $checksum"
[[ -f "$runtime_root/usr/lib/os-release" ]] || fail "runtime os-release not found: $runtime_root/usr/lib/os-release"
grep -Fq "SYSEXT_LEVEL=katl-runtime-1" "$runtime_root/usr/lib/os-release" || fail "runtime os-release missing SYSEXT_LEVEL=katl-runtime-1"

(cd "$(dirname "$artifact")" && sha256sum -c "$(basename "$checksum")")

size="$(stat -c %s "$artifact")"
sha256="$(sha256sum "$artifact" | awk '{print $1}')"
json_has '"name": "kubernetes"'
json_has '"kind": "sysext"'
json_has '"format": "sysext"'
payload_version="$(json_string_nonempty payloadVersion)"
kubeadm_metadata="$(json_string_nonempty kubeadm)"
resolved_payload="$(payload_version_from_package "$kubeadm_metadata")"
if [[ "$payload_version" != "$resolved_payload" ]]; then
    fail "payloadVersion = $payload_version, want $resolved_payload derived from kubeadm package"
fi
expected_payload="${KATL_KUBERNETES_PAYLOAD_VERSION:-}"
if [[ -n "$expected_payload" && "$payload_version" != "$expected_payload" ]]; then
    fail "payloadVersion = $payload_version, want $expected_payload"
fi
[[ "$payload_version" == "$KATL_KUBERNETES_MINOR."* ]] || fail "payloadVersion $payload_version does not match selected minor $KATL_KUBERNETES_MINOR"
json_has '"sourceRepo"'
json_has "\"id\": \"$KATL_KUBERNETES_REPO_ID\""
json_has "\"baseURL\": \"$KATL_KUBERNETES_REPO_BASEURL\""
json_has "\"minor\": \"$KATL_KUBERNETES_MINOR\""
json_has '"packageVersions"'
if [[ -n "${KATL_KUBERNETES_KUBEADM_VERSION:-}" && "$kubeadm_metadata" != "$KATL_KUBERNETES_KUBEADM_VERSION" ]]; then
    fail "metadata kubeadm = $kubeadm_metadata, want $KATL_KUBERNETES_KUBEADM_VERSION"
fi
json_expect_or_nonempty kubelet "${KATL_KUBERNETES_KUBELET_VERSION:-}"
json_expect_or_nonempty kubectl "${KATL_KUBERNETES_KUBECTL_VERSION:-}"
json_expect_or_nonempty cri-tools "${KATL_KUBERNETES_CRITOOLS_VERSION:-}"
json_has '"runtimeInterface": "katl-runtime-1"'
json_has '"compatibleRuntime"'
json_has "\"sizeBytes\": $size"
json_has "\"sha256\": \"$sha256\""

read -r start sectors < <(fdisk -l "$artifact" | awk -v name="$(basename "$artifact")" '$1 ~ name "1$" {print $2, $4; exit}')
[[ -n "${start:-}" && -n "${sectors:-}" ]] || fail "root partition not found in $artifact"

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT
part="$tmpdir/katl-kubernetes.erofs"
dd if="$artifact" of="$part" bs=512 skip="$start" count="$sectors" status=none
fsck.erofs "$part"

for path in \
    /usr/bin/kubeadm \
    /usr/bin/kubectl \
    /usr/bin/kubelet \
    /usr/bin/crictl \
    /usr/bin/conntrack \
    /usr/bin/ethtool \
    /usr/bin/socat \
    /usr/bin/iptables-nft
do
    has_path "$path"
done

release="$(dump.erofs --cat --path /usr/lib/extension-release.d/extension-release.katl-kubernetes "$part" 2>&1)"
grep -Fq "ID=fedora" <<<"$release" || fail "extension-release missing ID=fedora"
grep -Fq "SYSEXT_LEVEL=katl-runtime-1" <<<"$release" || fail "extension-release missing SYSEXT_LEVEL=katl-runtime-1"
grep -Fq "SYSEXT_ID=katl-kubernetes" <<<"$release" || fail "extension-release missing SYSEXT_ID"
grep -Fq "ARCHITECTURE=x86-64" <<<"$release" || fail "extension-release missing architecture"

for path in \
    /etc/yum.repos.d/kubernetes.repo \
    /usr/bin/bash \
    /usr/bin/helm \
    /usr/bin/flux \
    /usr/bin/cilium \
    /usr/bin/rook \
    /usr/bin/coredns
do
    misses_path "$path"
done

echo "ok: $artifact"
