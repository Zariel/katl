#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
build_dir="${KATL_VMTEST_ARTIFACTS_BUILD_DIR:-$repo_root/_build/mkosi}"
stamp_dir="$build_dir/.katl-stamps"
base_root="$build_dir/katl-runtime-base-root"
runtime_root="$build_dir/katl-runtime-root"
runtime_squashfs="${KATL_RUNTIME_ARTIFACT:-$build_dir/katl-runtime-root.squashfs}"
runtime_uki="${KATL_RUNTIME_UKI:-$build_dir/katl-runtime.efi}"
overlay_root="$build_dir/vmtest-runtime-overlay"
upper="$overlay_root/upper"
work="$overlay_root/work"
merged="$overlay_root/merged"
mkosi_cmd="${KATL_VMTEST_ARTIFACTS_MKOSI:-$repo_root/scripts/mkosi}"
runtime_build="${KATL_VMTEST_ARTIFACTS_RUNTIME_BUILD:-$repo_root/mkosi.profiles/runtime/mkosi.build}"
artifacts_tool="${KATL_VMTEST_ARTIFACTS_TOOL:-}"
filesystems="${KATL_VMTEST_ARTIFACTS_FILESYSTEMS:-/proc/filesystems}"
version="${KATL_VERSION:-0.0.0-dev}"
build_commit="$(git -C "$repo_root" describe --always --dirty --abbrev=12 2>/dev/null || printf unknown)"
architecture="${KATL_ARCHITECTURE:-$(uname -m)}"
mounted=0

fail() {
    echo "error: $*" >&2
    exit 1
}

need() {
    command -v "$1" >/dev/null 2>&1 || fail "$1 is required"
}

usage() {
    cat <<EOF
Usage: scripts/build-vmtest-artifacts [--runtime-only]

Prepare current vmtest runtime artifacts from a cached mkosi runtime base.
EOF
}

while (($# > 0)); do
    case "$1" in
        --runtime-only)
            # Accepted so vmtest-run can name the artifact mode explicitly.
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            fail "unknown argument: $1"
            ;;
    esac
    shift
done

under_repo() {
    local label="$1"
    local path="$2"
    [[ "$path" == "$repo_root"/* ]] || fail "$label must be under repository root: $path"
}

mkosi_artifacts() {
    if [[ -n "$artifacts_tool" ]]; then
        "$artifacts_tool" "$@"
        return
    fi
    if command -v katl-mkosi-artifacts >/dev/null 2>&1; then
        katl-mkosi-artifacts "$@"
        return
    fi
    (cd "$repo_root" && go run ./cmd/katl-mkosi-artifacts "$@")
}

list_repo_inputs() {
    {
        git -C "$repo_root" ls-files -z
        git -C "$repo_root" ls-files --others --exclude-standard -z
    } | while IFS= read -r -d "" path; do
        case "$path" in
            .beads/* | _build/* | */_build/* | build/* | */build/*)
                continue
                ;;
        esac
        printf '%s\0' "$path"
    done | sort -z
}

input_matches_target() {
    local target="$1"
    local path="$2"
    case "$path" in
        *_test.go | docs/*)
            return 1
            ;;
        Containerfile.mkosi | containers-policy.json | mkosi.conf | mkosi.profiles/resource-package-lock.json | scripts/mkosi)
            return 0
            ;;
    esac
    case "$target" in
        runtime-base)
            case "$path" in
                mkosi.profiles/runtime-base/*)
                    return 0
                    ;;
            esac
            ;;
    esac
    return 1
}

fingerprint() {
    local target="$1"
    local path file_digest
    {
        printf 'target=%s\n' "$target"
        printf 'KATL_VERSION=%s\n' "$version"
        printf 'KATL_ARCHITECTURE=%s\n' "$architecture"
        printf 'KATL_MKOSI_IMAGE=%s\n' "${KATL_MKOSI_IMAGE:-}"
        while IFS= read -r -d "" path; do
            if input_matches_target "$target" "$path"; then
                if [[ -f "$repo_root/$path" ]]; then
                    read -r file_digest _ < <(sha256sum "$repo_root/$path")
                    printf 'file %s %s\n' "$path" "$file_digest"
                else
                    printf 'missing %s\n' "$path"
                fi
            fi
        done < <(list_repo_inputs)
    } | sha256sum | awk '{print $1}'
}

stamp_matches() {
    local target="$1"
    local stamp="$stamp_dir/$target.sha256"
    [[ -f "$stamp" ]] || return 1
    [[ "$(<"$stamp")" == "$(fingerprint "$target")" ]]
}

store_stamp() {
    local target="$1"
    mkdir -p "$stamp_dir"
    fingerprint "$target" >"$stamp_dir/$target.sha256"
}

validate_overlayfs() {
    need mount
    need umount
    [[ -r "$filesystems" ]] || fail "overlayfs availability file is not readable: $filesystems"
    if ! awk '{print $NF}' "$filesystems" | grep -qx overlay; then
        fail "overlayfs is required for vmtest artifact prep; overlay is not listed in $filesystems"
    fi
}

cleanup_mount() {
    if [[ "$mounted" == 1 ]]; then
        umount "$merged" >/dev/null 2>&1 || true
        mounted=0
    fi
}

trap cleanup_mount EXIT

build_runtime_base() {
    if [[ -d "$base_root" ]] && stamp_matches runtime-base; then
        printf 'vmtest artifacts: runtime-base cache hit\n' >&2
        return
    fi
    printf 'vmtest artifacts: building runtime-base with mkosi\n' >&2
    "$mkosi_cmd" --profile runtime-base -f build
    [[ -d "$base_root" ]] || fail "runtime-base output is missing: $base_root"
    store_stamp runtime-base
}

build_overlay_upper() {
    rm -rf -- "$overlay_root"
    mkdir -p "$upper" "$work" "$merged" "$overlay_root/build"
    BUILDDIR="$overlay_root/build" \
        SRCDIR="$repo_root" \
        DESTDIR="$upper" \
        KATL_VERSION="$version" \
        KATL_BUILD_COMMIT="$build_commit" \
        KATL_GOMODCACHE="${KATL_GOMODCACHE:-$repo_root/_build/go-mod}" \
        "$runtime_build"
    cp -a "$repo_root/mkosi.profiles/runtime/mkosi.extra/." "$upper/"
    mkdir -p "$upper/usr/lib/systemd/system/multi-user.target.wants"
    ln -sfn ../systemd-networkd.service "$upper/usr/lib/systemd/system/multi-user.target.wants/systemd-networkd.service"
}

mount_overlay() {
    if ! mount -t overlay overlay -o "lowerdir=$base_root,upperdir=$upper,workdir=$work" "$merged"; then
        fail "could not mount overlayfs for vmtest artifact prep; run on a host that permits overlay mounts"
    fi
    mounted=1
}

write_runtime_artifacts() {
    local kernel_dir kernel initrd os_release kernel_version runtime_sha
    rm -rf -- "$runtime_root"
    cp -a "$merged" "$runtime_root"
    rm -f -- "$runtime_squashfs" "$runtime_squashfs.sha256" "$runtime_squashfs.json" "$runtime_uki" "$runtime_uki.sha256" "$runtime_uki.json"
    mksquashfs "$merged" "$runtime_squashfs" -noappend -all-root -comp zstd >/dev/null
    runtime_sha="$(mkosi_artifacts write-runtime-root --artifact "$runtime_squashfs")"

    kernel_dir="$(find "$merged/boot" -type f -name linux -printf "%h\n" | sort | head -n 1)"
    [[ -n "$kernel_dir" ]] || fail "runtime kernel not found under merged runtime root"
    kernel="$kernel_dir/linux"
    initrd="$kernel_dir/initrd"
    os_release="$merged/usr/lib/os-release"
    kernel_version="$(basename "$kernel_dir")"
    [[ -f "$initrd" ]] || fail "runtime initrd not found: $initrd"
    [[ -f "$os_release" ]] || fail "runtime os-release not found: $os_release"

    ukify_args=(
        build
        --linux "$kernel"
        --initrd "$initrd"
        --os-release "@$os_release"
        --cmdline "rootfstype=squashfs ro"
        --uname "$kernel_version"
        --output "$runtime_uki"
    )
    if [[ -f /usr/lib/systemd/boot/efi/linuxx64.efi.stub ]]; then
        ukify_args+=(--stub /usr/lib/systemd/boot/efi/linuxx64.efi.stub)
    fi
    ukify "${ukify_args[@]}"
    mkosi_artifacts write-runtime-uki \
        --artifact "$runtime_uki" \
        --runtime-artifact "$runtime_squashfs" \
        --runtime-sha256 "$runtime_sha" \
        --kernel-version "$kernel_version" >/dev/null
}

need awk
need cp
need find
need grep
need ln
need mkdir
need mksquashfs
need rm
need sha256sum
need sort
need ukify
under_repo "vmtest artifact build directory" "$build_dir"
mkdir -p "$build_dir"
validate_overlayfs
build_runtime_base
build_overlay_upper
mount_overlay
write_runtime_artifacts
cleanup_mount
printf 'vmtest artifacts: prepared runtime artifacts in %s\n' "${build_dir#"$repo_root"/}" >&2
