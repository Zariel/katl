#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
run_id="${KATL_SMOKE_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
state_root="${KATL_SMOKE_STATE_ROOT:-$repo_root/build/mkosi-smoke}"
state_dir="${KATL_SMOKE_STATE_DIR:-$state_root/$run_id}"
vm_dir="$state_dir/vm"
index="$state_dir/artifacts.env"
build_index="${KATL_BUILD_ARTIFACT_INDEX:-$repo_root/build/mkosi/artifacts.json}"
installer_uki=
installer_kernel=
installer_initrd=
runtime_uki=
runtime_artifact=
expect="${KATL_SMOKE_EXPECT:-Katl installer ready}"
timeout_duration="${KATL_SMOKE_TIMEOUT:-120s}"
kvm="${KATL_SMOKE_KVM:-auto}"
ram="${KATL_SMOKE_RAM:-2048}"
cpus="${KATL_SMOKE_CPUS:-2}"
status=starting

rel() {
    local path="$1"
    printf "%s" "${path#"$repo_root"/}"
}

need_file() {
    local label="$1"
    local path="$2"
    if [[ ! -f "$path" ]]; then
        echo "error: $label not found: $(rel "$path")" >&2
        exit 1
    fi
}

save_index() {
    mkdir -p "$state_dir"
    {
        printf 'STATUS=%q\n' "$status"
        printf 'RUN_DIR=%q\n' "$state_dir"
        printf 'BUILD_ARTIFACT_INDEX=%q\n' "$build_index"
        printf 'INSTALLER_UKI=%q\n' "$installer_uki"
        printf 'INSTALLER_KERNEL=%q\n' "$installer_kernel"
        printf 'INSTALLER_INITRD=%q\n' "$installer_initrd"
        printf 'RUNTIME_UKI=%q\n' "$runtime_uki"
        printf 'RUNTIME_SQUASHFS=%q\n' "$runtime_artifact"
        printf 'VM_STATE_DIR=%q\n' "$vm_dir"
        printf 'SERIAL_LOG=%q\n' "$vm_dir/serial.log"
        printf 'QEMU_COMMAND=%q\n' "$vm_dir/qemu-command.txt"
        printf 'FIRMWARE_VARS=%q\n' "$vm_dir/OVMF_VARS.fd"
        printf 'EXPECT=%q\n' "$expect"
    } >"$index"
}

finish() {
    local code=$?
    if [[ "$code" -ne 0 ]]; then
        status=failed
        save_index || true
        echo "error: mkosi smoke failed" >&2
        echo "artifact index: $(rel "$index")" >&2
        echo "build artifact index: $(rel "$build_index")" >&2
        echo "serial log: $(rel "$vm_dir/serial.log")" >&2
    fi
}
trap finish EXIT

status=building
save_index

echo "building installer-image profile"
"$repo_root/scripts/mkosi" build-installer

echo "building runtime profile"
"$repo_root/scripts/mkosi" build-runtime

"$repo_root/scripts/mkosi-artifacts" write "$build_index"
installer_uki="$("$repo_root/scripts/mkosi-artifacts" path installer-uki "$build_index")"
installer_kernel="$("$repo_root/scripts/mkosi-artifacts" path installer-kernel "$build_index")"
installer_initrd="$("$repo_root/scripts/mkosi-artifacts" path installer-initrd "$build_index")"
runtime_uki="$("$repo_root/scripts/mkosi-artifacts" path runtime-uki "$build_index")"
runtime_artifact="$("$repo_root/scripts/mkosi-artifacts" path runtime-root "$build_index")"
need_file "installer UKI" "$installer_uki"
need_file "installer kernel" "$installer_kernel"
need_file "installer initrd" "$installer_initrd"
need_file "runtime UKI" "$runtime_uki"
need_file "runtime SquashFS" "$runtime_artifact"

status=booting
save_index

echo "booting installer-image profile"
"$repo_root/scripts/katl-vm" \
    --uki "$installer_uki" \
    --state-dir "$vm_dir" \
    --expect "$expect" \
    --timeout "$timeout_duration" \
    --kvm "$kvm" \
    --ram "$ram" \
    --cpus "$cpus"

need_file "serial log" "$vm_dir/serial.log"
need_file "QEMU command" "$vm_dir/qemu-command.txt"
need_file "firmware vars copy" "$vm_dir/OVMF_VARS.fd"

status=passed
save_index
trap - EXIT

echo "artifact index: $(rel "$index")"
echo "build artifact index: $(rel "$build_index")"
echo "serial log: $(rel "$vm_dir/serial.log")"
echo "ok: mkosi smoke passed"
