#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
default_index="$repo_root/build/mkosi/artifacts.json"
installer_uki="${KATL_INSTALLER_UKI:-$repo_root/build/mkosi/katl-installer.efi}"
installer_kernel="${KATL_INSTALLER_KERNEL:-$repo_root/build/mkosi/katl-installer.vmlinuz}"
installer_initrd="${KATL_INSTALLER_INITRD:-$repo_root/build/mkosi/katl-installer.initrd}"
runtime_uki="${KATL_RUNTIME_UKI:-$repo_root/build/mkosi/katl-runtime.efi}"
runtime_uki_metadata="${KATL_RUNTIME_UKI_METADATA:-$runtime_uki.json}"
runtime_uki_checksum="${KATL_RUNTIME_UKI_CHECKSUM:-$runtime_uki.sha256}"
runtime_artifact="${KATL_RUNTIME_ARTIFACT:-$repo_root/build/mkosi/katl-runtime-root.squashfs}"
runtime_metadata="${KATL_RUNTIME_METADATA:-$runtime_artifact.json}"
runtime_checksum="${KATL_RUNTIME_CHECKSUM:-$runtime_artifact.sha256}"
generation="$(git -C "$repo_root" describe --always --dirty --abbrev=12 2>/dev/null || printf unknown)"
version="${KATL_VERSION:-0.0.0-dev}"
architecture="${KATL_ARCHITECTURE:-$(uname -m)}"
installer_interface="${KATL_INSTALLER_INTERFACE:-katl-installer-boot-1}"
katlos_image_default="$repo_root/build/mkosi/katlos-install-${version}-${architecture}.squashfs"
katlos_image="${KATL_KATLOS_IMAGE:-$katlos_image_default}"
katlos_image_metadata="${KATL_KATLOS_IMAGE_METADATA:-$katlos_image.json}"
katlos_image_checksum="${KATL_KATLOS_IMAGE_CHECKSUM:-$katlos_image.sha256}"

usage() {
    cat <<'USAGE'
Usage: scripts/mkosi-artifacts [write [INDEX]]
       scripts/mkosi-artifacts path KIND [INDEX]

Write or query the local mkosi artifact index.

Kinds:
  installer-uki
  installer-kernel
  installer-initrd
  runtime-uki
  runtime-root
  katlos-install-image
USAGE
}

fail() {
    echo "error: $*" >&2
    exit 1
}

need() {
    command -v "$1" >/dev/null 2>&1 || fail "$1 is required"
}

rel() {
    local path="$1"
    printf "%s" "${path#"$repo_root"/}"
}

artifact_rel() {
    local path="$1"
    if [[ "$path" != "$repo_root"/* ]]; then
        fail "artifact path must be under repository root for local index: $path"
    fi
    rel "$path"
}

abs() {
    local path="$1"
    if [[ "$path" == /* ]]; then
        printf "%s" "$path"
    else
        printf "%s/%s" "$repo_root" "$path"
    fi
}

need_file() {
    local label="$1"
    local path="$2"
    [[ -f "$path" ]] || fail "$label not found: $(rel "$path")"
}

katlos_image_available() {
    [[ -f "$katlos_image" ]] || [[ -n "${KATL_KATLOS_IMAGE:-}" ]]
}

sha() {
    sha256sum "$1" | awk '{print $1}'
}

checksum_path() {
    local path="$1"
    printf "%s.sha256" "$path"
}

metadata_path() {
    local path="$1"
    printf "%s.json" "$path"
}

write_checksum() {
    local path="$1"
    local checksum
    checksum="$(checksum_path "$path")"
    printf "%s  %s\n" "$(sha "$path")" "$(basename "$path")" >"$checksum"
}

write_boot_metadata() {
    local role="$1"
    local format="$2"
    local path="$3"
    local created="$4"
    local metadata size digest rel_path
    metadata="$(metadata_path "$path")"
    size="$(stat -c %s "$path")"
    digest="$(sha "$path")"
    rel_path="$(artifact_rel "$path")"

    jq -n \
        --arg apiVersion "katl.dev/v1alpha1" \
        --arg kind "InstallerBootArtifact" \
        --arg artifactRole "$role" \
        --arg format "$format" \
        --arg version "$version" \
        --arg buildID "$generation" \
        --arg architecture "$architecture" \
        --arg path "$rel_path" \
        --arg sha256 "$digest" \
        --arg createdAt "$created" \
        --arg installerInterface "$installer_interface" \
        --argjson sizeBytes "$size" \
        '{
          apiVersion: $apiVersion,
          kind: $kind,
          artifactRole: $artifactRole,
          format: $format,
          version: $version,
          buildID: $buildID,
          architecture: $architecture,
          path: $path,
          sizeBytes: $sizeBytes,
          sha256: $sha256,
          createdAt: $createdAt,
          installerInterface: $installerInterface,
          defaultKernelCommandLine: [
            "console=ttyS0,115200n8",
            "systemd.log_target=console",
            "loglevel=6"
          ],
          supportedInputModes: [
            "pxe-preseed",
            "local-handoff",
            "offline-media"
          ]
        }' >"$metadata"
}

entry() {
    local kind="$1"
    local format="$2"
    local path="$3"
    local metadata="$4"
    local checksum="$5"
    local size digest rel_path
    size="$(stat -c %s "$path")"
    digest="$(sha "$path")"
    rel_path="$(artifact_rel "$path")"

    jq -n \
        --arg kind "$kind" \
        --arg path "$rel_path" \
        --arg format "$format" \
        --arg sha256 "$digest" \
        --arg metadataPath "$(rel "$metadata")" \
        --arg checksumPath "$(rel "$checksum")" \
        --argjson sizeBytes "$size" \
        '{
          kind: $kind,
          path: $path,
          format: $format,
          sizeBytes: $sizeBytes,
          sha256: $sha256
        }
        | if $metadataPath == "" then . else .metadataPath = $metadataPath end
        | if $checksumPath == "" then . else .checksumPath = $checksumPath end'
}

write_index() {
    local index="$1"
    local created
    need awk
    need date
    need jq
    need sha256sum
    need stat
    need_file "installer UKI" "$installer_uki"
    need_file "installer kernel" "$installer_kernel"
    need_file "installer initrd" "$installer_initrd"
    need_file "runtime UKI" "$runtime_uki"
    need_file "runtime UKI metadata" "$runtime_uki_metadata"
    need_file "runtime UKI checksum" "$runtime_uki_checksum"
    need_file "runtime SquashFS" "$runtime_artifact"
    need_file "runtime metadata" "$runtime_metadata"
    need_file "runtime checksum" "$runtime_checksum"
    if katlos_image_available; then
        need_file "KatlOS install image" "$katlos_image"
        need_file "KatlOS install image metadata" "$katlos_image_metadata"
        need_file "KatlOS install image checksum" "$katlos_image_checksum"
    fi

    created="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    write_checksum "$installer_uki"
    write_boot_metadata installer-uki uki "$installer_uki" "$created"
    write_checksum "$installer_kernel"
    write_boot_metadata installer-kernel linux-kernel "$installer_kernel" "$created"
    write_checksum "$installer_initrd"
    write_boot_metadata installer-initrd initrd "$installer_initrd" "$created"
    mkdir -p "$(dirname "$index")"
    artifacts=(
        "$(entry installer-uki uki "$installer_uki" "$(metadata_path "$installer_uki")" "$(checksum_path "$installer_uki")")"
        "$(entry installer-kernel linux-kernel "$installer_kernel" "$(metadata_path "$installer_kernel")" "$(checksum_path "$installer_kernel")")"
        "$(entry installer-initrd initrd "$installer_initrd" "$(metadata_path "$installer_initrd")" "$(checksum_path "$installer_initrd")")"
        "$(entry runtime-uki uki "$runtime_uki" "$runtime_uki_metadata" "$runtime_uki_checksum")"
        "$(entry runtime-root squashfs "$runtime_artifact" "$runtime_metadata" "$runtime_checksum")"
    )
    if katlos_image_available; then
        artifacts+=("$(entry katlos-install-image squashfs "$katlos_image" "$katlos_image_metadata" "$katlos_image_checksum")")
    fi
    jq -n \
        --arg generatedAt "$created" \
        --arg generation "$generation" \
        --argjson artifacts "$(printf '%s\n' "${artifacts[@]}" | jq -s '.')" \
        '{
          schemaVersion: 1,
          generatedAt: $generatedAt,
          generation: $generation,
          artifacts: $artifacts
        }' >"$index"
    echo "artifact index: $(rel "$index")"
}

path_for() {
    local kind="$1"
    local index="$2"
    local path count
    [[ -f "$index" ]] || fail "artifact index not found: $(rel "$index")"
    need jq
    count="$(jq -er --arg kind "$kind" '[.artifacts[]? | select(.kind == $kind)] | length' "$index")"
    case "$count" in
        0)
            fail "artifact kind not found in $(rel "$index"): $kind"
            ;;
        1)
            ;;
        *)
            fail "artifact kind appears more than once in $(rel "$index"): $kind"
            ;;
    esac
    path="$(jq -er --arg kind "$kind" '.artifacts[] | select(.kind == $kind) | .path' "$index")"
    abs "$path"
}

command="${1:-write}"
case "$command" in
    write)
        shift || true
        write_index "${1:-$default_index}"
        ;;
    path)
        shift || true
        [[ $# -ge 1 ]] || fail "path requires KIND"
        kind="$1"
        shift
        path_for "$kind" "${1:-$default_index}"
        ;;
    -h|--help)
        usage
        ;;
    *)
        usage >&2
        fail "unknown command: $command"
        ;;
esac
