# shellcheck shell=bash
# shellcheck disable=SC2034
: "${KATL_KUBERNETES_MINOR:=v1.36}"
: "${KATL_KUBERNETES_REPO_ID:=kubernetes}"

if [[ ! "$KATL_KUBERNETES_MINOR" =~ ^v[0-9]+\.[0-9]+$ ]]; then
    echo "error: KATL_KUBERNETES_MINOR must look like v1.36, got $KATL_KUBERNETES_MINOR" >&2
    return 1 2>/dev/null || exit 1
fi

: "${KATL_KUBERNETES_REPO_BASEURL:=https://pkgs.k8s.io/core:/stable:/${KATL_KUBERNETES_MINOR}/rpm/}"
: "${KATL_KUBERNETES_REPO_GPGKEY:=${KATL_KUBERNETES_REPO_BASEURL%/}/repodata/repomd.xml.key}"

# Optional exact expectations. When left empty, scripts/mkosi records the exact
# resolved RPM versions and derives the metadata payload version from kubeadm.
# When set, KATL_KUBERNETES_PAYLOAD_VERSION must match that resolved value.
: "${KATL_KUBERNETES_PAYLOAD_VERSION:=}"
: "${KATL_KUBERNETES_KUBEADM_VERSION:=}"
: "${KATL_KUBERNETES_KUBELET_VERSION:=}"
: "${KATL_KUBERNETES_KUBECTL_VERSION:=}"
: "${KATL_KUBERNETES_CRITOOLS_VERSION:=}"
: "${KATL_KUBERNETES_ETHTOOL_VERSION:=}"
: "${KATL_KUBERNETES_SOCAT_VERSION:=}"
